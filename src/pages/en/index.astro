---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { useTranslations } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout lang={lang} title="Rodrigo Salvador — Full-Stack Developer">
    <main id="top" class="max-w-5xl mx-auto px-6 pt-16 pb-12 md:pb-20">
        <!-- ═══════════════════════════════════════
         HERO SECTION
    ════════════════════════════════════════ -->
        <section
            class="min-h-[88vh] flex flex-col justify-center items-center text-center mb-32 relative"
            id="hero"
        >
            <!-- Radial glow bg -->
            <div class="absolute inset-0 z-0 pointer-events-none">
                <div
                    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-cyber-cyan/5 blur-3xl"
                >
                </div>
                <div
                    class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-cyber-purple/5 blur-3xl"
                >
                </div>
            </div>

            <div
                class="relative z-10 flex flex-col items-center animate-on-scroll"
            >
                <!-- Avatar with neon ring -->
                <div class="relative mb-8">
                    <!-- Rotating neon ring -->
                    <div
                        class="absolute inset-0 rounded-full animate-spin"
                        style="animation-duration: 6s; background: conic-gradient(from 0deg, transparent, #00d4ff, transparent, #7c3aed, transparent); padding: 3px; border-radius: 9999px; margin: -6px;"
                    >
                    </div>
                    <!-- Glow blur -->
                    <div
                        class="absolute inset-0 rounded-full blur-xl bg-cyber-cyan/30 scale-110"
                    >
                    </div>
                    <img
                        class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border-2 border-cyber-cyan/50 relative z-10"
                        src="/avatar.png"
                        alt="Rodrigo Salvador"
                    />
                    <!-- Status dot -->
                    <div
                        class="absolute bottom-1 right-1 z-20 flex items-center justify-center"
                    >
                        <span
                            class="w-4 h-4 rounded-full bg-cyber-green border-2 border-cyber-bg animate-pulse"
                        ></span>
                    </div>
                </div>

                <!-- Greeting -->
                <p
                    class="text-sm font-mono-cyber text-cyber-cyan mb-2 tracking-widest uppercase opacity-80"
                >
                    &gt;_ {t("hero.greeting")}
                    <span class="text-white font-semibold"
                        >{t("hero.name")}</span
                    >
                </p>

                <!-- Main heading with glitch effect -->
                <h1
                    class="glitch text-5xl md:text-7xl font-extrabold mb-6 tracking-tighter text-white leading-tight"
                    data-text={`${t("hero.title")} ${t("hero.titleAccent")}`}
                >
                    {t("hero.title")}
                    <span
                        class="text-cyber-cyan"
                        style="text-shadow: 0 0 20px rgba(0,212,255,0.5);"
                        >{t("hero.titleAccent")}</span
                    >
                </h1>

                <!-- Typewriter subtitle -->
                <div
                    class="text-base md:text-lg text-gray-500 font-mono-cyber mb-10 h-7 flex items-center gap-1"
                >
                    <span id="typewriter-text"></span>
                    <span
                        class="w-0.5 h-5 bg-cyber-cyan"
                        style="animation: blink-cursor 1s step-end infinite;"
                    ></span>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-wrap gap-4 justify-center mb-12">
                    <a href="#contacto" class="btn-cyber-primary px-7 py-3">
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                            ></path>
                        </svg>
                        <span>{t("hero.ctaTalk")}</span>
                    </a>
                    <a href="#proyectos" class="btn-cyber-secondary px-7 py-3">
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path>
                        </svg>
                        {t("hero.ctaWork")}
                    </a>
                </div>

                <!-- Social links -->
                <div class="flex items-center gap-5 text-gray-600">
                    <a
                        href="https://github.com/Rodrigojsr12"
                        target="_blank"
                        class="hover:text-cyber-cyan transition-colors group"
                    >
                        <svg
                            class="w-5 h-5 group-hover:drop-shadow-[0_0_6px_rgba(0,212,255,0.8)]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </a>
                    <div class="w-px h-4 bg-gray-800"></div>
                    <a
                        href="https://www.linkedin.com/in/rodrigojsr12/"
                        target="_blank"
                        class="hover:text-cyber-cyan transition-colors group"
                    >
                        <svg
                            class="w-5 h-5 group-hover:drop-shadow-[0_0_6px_rgba(0,212,255,0.8)]"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </section>

        <!-- ═══════════════════════════════════════
         ABOUT SECTION
    ════════════════════════════════════════ -->
        <section id="sobre-mi" class="mb-32">
            <div class="text-center mb-14 animate-on-scroll">
                <div class="section-badge">
                    <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                    {t("about.badge")}
                </div>
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
                    {t("about.heading")}
                </h2>
                <p class="text-gray-500 max-w-xl mx-auto">
                    {t("about.subheading")}
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
                <!-- Animated code block -->
                <div
                    class="cyber-card p-6 font-mono-cyber text-sm leading-relaxed animate-on-scroll"
                    id="code-block"
                >
                    <div class="flex items-center gap-2 mb-4">
                        <div class="flex gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500/70"
                            ></span>
                            <span
                                class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"
                            ></span>
                            <span
                                class="w-2.5 h-2.5 rounded-full bg-green-500/70"
                            ></span>
                        </div>
                        <span class="text-gray-600 text-xs ml-2"
                            >&gt;_ developer.ts</span
                        >
                    </div>
                    <div id="code-content">
                        <div class="text-[#c678dd]">
                            interface <span class="text-[#e5c07b]"
                                >Developer</span
                            >
                            {"{"}
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">name</span>: <span
                                    class="text-[#98c379]">string</span
                                >;
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">status</span>: <span
                                    class="text-[#98c379]">string</span
                                >;
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">focus</span>: <span
                                    class="text-[#98c379]">string</span
                                >;
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">stack</span>: <span
                                    class="text-[#98c379]">string[]</span
                                >;
                            </div>
                            <div class="text-[#c678dd]">{"}"}</div>
                        </div>
                        <br />
                        <div class="text-[#c678dd]">
                            const <span class="text-[#61afef]">rodrigo</span>:
                            Developer = {"{"}
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">name</span>: <span
                                    class="text-[#98c379]"
                                    >{t("about.code.name")}</span
                                >,
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">status</span>: <span
                                    class="text-[#98c379]"
                                    >{t("about.code.status")}</span
                                >,
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">focus</span>: <span
                                    class="text-[#98c379]"
                                    >{t("about.code.focus")}</span
                                >,
                            </div>
                            <div class="ml-4 text-gray-300">
                                <span class="text-cyber-cyan">stack</span>: [<span
                                    class="text-[#98c379]">"React"</span
                                >, <span class="text-[#98c379]">"Python"</span>, <span
                                    class="text-[#98c379]">"Data"</span
                                >],
                            </div>
                            <div class="text-[#c678dd]">
                                {"}"}<span class="text-gray-300">;</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Text side -->
                <div class="animate-on-scroll">
                    <h3 class="text-2xl font-bold text-white mb-5">
                        {t("about.focus.title")}
                    </h3>
                    <div
                        class="text-gray-400 leading-relaxed space-y-4 text-base"
                    >
                        <p set:html={t("about.p1")} />
                        <p>{t("about.p2")}</p>
                        <p>{t("about.p3")}</p>
                    </div>
                    <div class="mt-8 flex flex-wrap gap-3">
                        {
                            [
                                "React",
                                "Angular",
                                "C#",
                                "Python",
                                "TypeScript",
                                "Astro",
                                "FastAPI",
                                "Spring Boot",
                                "Flutter",
                            ].map((tech) => (
                                <span class="skill-tag">{tech}</span>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══════════════════════════════════════
         SKILLS SECTION
    ════════════════════════════════════════ -->
        <section id="habilidades" class="mb-32">
            <div class="text-center mb-14 animate-on-scroll">
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                    {t("skills.heading")}
                </h2>
                <p class="text-gray-500">{t("skills.subheading")}</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
                <!-- Frontend -->
                <div class="cyber-card p-6 animate-on-scroll">
                    <h3
                        class="text-white font-bold mb-5 flex items-center gap-2"
                    >
                        <span class="text-cyber-cyan">
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                        </span>
                        {t("skills.frontend")}
                    </h3>
                    <div class="space-y-3">
                        {
                            [
                                { name: "React", level: 80 },
                                { name: "Angular", level: 75 },
                                { name: "Astro", level: 75 },
                                { name: "TypeScript", level: 70 },
                                { name: "Tailwind CSS", level: 85 },
                            ].map((skill) => (
                                <div>
                                    <div class="flex justify-between text-xs mb-1">
                                        <span class="text-gray-400 font-mono-cyber">
                                            {skill.name}
                                        </span>
                                        <span class="text-cyber-cyan/60">
                                            {skill.level}%
                                        </span>
                                    </div>
                                    <div class="h-1 bg-cyber-border rounded-full overflow-hidden">
                                        <div
                                            class="h-full rounded-full skill-bar"
                                            style={`width: ${skill.level}%; background: linear-gradient(90deg, #00d4ff, #7c3aed);`}
                                        />
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Data & Backend -->
                <div class="cyber-card p-6 animate-on-scroll">
                    <h3
                        class="text-white font-bold mb-5 flex items-center gap-2"
                    >
                        <span class="text-cyber-purple">
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"
                                ></path>
                            </svg>
                        </span>
                        {t("skills.backend")}
                    </h3>
                    <div class="space-y-3">
                        {
                            [
                                { name: "Python", level: 85 },
                                { name: "FastAPI", level: 70 },
                                { name: "PostgreSQL", level: 65 },
                                { name: "Excel / PowerBI", level: 60 },
                            ].map((skill) => (
                                <div>
                                    <div class="flex justify-between text-xs mb-1">
                                        <span class="text-gray-400 font-mono-cyber">
                                            {skill.name}
                                        </span>
                                        <span class="text-cyber-purple/80">
                                            {skill.level}%
                                        </span>
                                    </div>
                                    <div class="h-1 bg-cyber-border rounded-full overflow-hidden">
                                        <div
                                            class="h-full rounded-full skill-bar"
                                            style={`width: ${skill.level}%; background: linear-gradient(90deg, #7c3aed, #00d4ff);`}
                                        />
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Tools -->
                <div class="cyber-card p-6 animate-on-scroll">
                    <h3
                        class="text-white font-bold mb-5 flex items-center gap-2"
                    >
                        <span class="text-cyber-cyan">
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </span>
                        {t("skills.tools")}
                    </h3>
                    <div class="flex flex-wrap gap-2.5 mt-2">
                        {
                            [
                                "VS Code",
                                "GitHub",
                                "MySQL Workbench",
                                "Postman",
                                "Docker",
                                "Trello",
                                "Jira",
                                "MS Office",
                                "Excel",
                                "Power BI",
                                "Figma",
                                "Linux",
                            ].map((tool) => (
                                <span class="skill-tag">{tool}</span>
                            ))
                        }
                    </div>
                </div>

                <!-- Languages -->
                <div class="cyber-card p-6 animate-on-scroll">
                    <h3
                        class="text-white font-bold mb-5 flex items-center gap-2"
                    >
                        <span class="text-cyber-cyan">
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                                ></path>
                            </svg>
                        </span>
                        {t("skills.languages")}
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <div class="flex justify-between text-xs mb-1">
                                <span class="text-gray-300 font-medium"
                                    >🇪🇸 {t("skills.spanish")}</span
                                >
                                <span class="text-cyber-cyan/80 font-mono-cyber"
                                    >{t("skills.native")}</span
                                >
                            </div>
                            <div
                                class="h-1 bg-cyber-border rounded-full overflow-hidden"
                            >
                                <div
                                    class="h-full rounded-full skill-bar"
                                    style="width: 100%; background: linear-gradient(90deg, #00d4ff, #7c3aed);"
                                >
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs mb-1">
                                <span class="text-gray-300 font-medium"
                                    >🇺🇸 {t("skills.english")}</span
                                >
                                <span class="text-cyber-cyan/80 font-mono-cyber"
                                    >{t("skills.englishLevel")}</span
                                >
                            </div>
                            <div
                                class="h-1 bg-cyber-border rounded-full overflow-hidden"
                            >
                                <div
                                    class="h-full rounded-full skill-bar"
                                    style="width: 70%; background: linear-gradient(90deg, #00d4ff, #7c3aed);"
                                >
                                </div>
                            </div>
                            <p
                                class="text-gray-500 text-xs mt-2 font-mono-cyber"
                            >
                                {t("skills.englishDesc")}
                            </p>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════
         PROJECTS SECTION
    ════════════════════════════════════════ -->
                <section id="proyectos" class="mb-32">
                    <div class="text-center mb-14 animate-on-scroll">
                        <h2
                            class="text-3xl md:text-4xl font-bold text-white mb-4"
                        >
                            {t("projects.heading")}
                        </h2>
                        <p class="text-gray-500">{t("projects.subheading")}</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
                        <div class="animate-on-scroll">
                            <ProjectCard
                                title={t("projects.p1.title")}
                                description={t("projects.p1.desc")}
                                tags={["Astro", "Tailwind", "UI/UX"]}
                                link="https://github.com/tu-usuario/proyecto-1"
                                badge={t("projects.badge")}
                            />
                        </div>
                        <div class="animate-on-scroll">
                            <ProjectCard
                                title={t("projects.p2.title")}
                                description={t("projects.p2.desc")}
                                tags={["Finance", "Data", "Excel"]}
                                link="https://github.com/tu-usuario/proyecto-2"
                                badge={t("projects.badge")}
                            />
                        </div>
                        <div class="animate-on-scroll">
                            <ProjectCard
                                title={t("projects.p3.title")}
                                description={t("projects.p3.desc")}
                                tags={["Math", "Algorithms", "Python"]}
                                link="https://github.com/tu-usuario/proyecto-3"
                                badge={t("projects.badge")}
                            />
                        </div>
                        <div class="animate-on-scroll">
                            <ProjectCard
                                title={t("projects.p4.title")}
                                description={t("projects.p4.desc")}
                                tags={["Research", "Data"]}
                                link="https://github.com/tu-usuario/proyecto-4"
